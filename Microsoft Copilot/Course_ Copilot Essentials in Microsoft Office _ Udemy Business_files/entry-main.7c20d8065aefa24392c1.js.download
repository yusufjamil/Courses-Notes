preview email");gettext("Send preview email?");gettext("Send");gettext("We'll send the announcement preview. Proceed?");gettext("Filter recipients by");gettext("Choose the type of announcement you want to send to your learners.");gettext("Type of announcement");gettext("You must select an announcement type.");gettext("Educational announcement");gettext("Share updates and important information about your course. These will be sent via email and appear in the course dashboard. Only external links are allowed; Udemy links are not permitted.");gettext("Up to 4 per course, per month");gettext("Promotional email");gettext("Promote and highlight your other courses. These emails will be sent to learners and also appear in their message box. Include only Udemy links; external links are not allowed.");gettext("Up to 2 per course, per month");gettext("New Educational Announcement");gettext("New Promotional Announcement");gettext("Audience");gettext("Define who you want to send the announcement to. You can select courses and then filter learners by enrollment date, course progress, etc.");gettext("Courses");gettext("Clear selection");gettext("Clear filters");gettext("Bulk selection");gettext("Select by langage");gettext("No results found");gettext("Content");gettext("Subject");gettext("This will be the subject of your email");gettext("Announcement and email title (%(max)s character max)");gettext("Body");gettext("Insert your content here. Please make sure that the announcement follows our policies.");gettext("Search for courses");gettext("Select all eligible courses");gettext("Preview");gettext("Enrollment date");gettext("Include students who enrolled after");gettext("Include students who enrolled before");gettext("Course progress");gettext("Engage learners according to their course progress. Whether they're just starting, making progress, or have completed the course, customize your messages to suit their stage.");gettext("Refine your announcements by excluding learners enrolled in selected courses. For example, you can exclude learners who enrolled in a specific course or who have completed a certain number of courses.");gettext("Exclude students by course");gettext("Excluded courses");gettext("Reach learners based on their enrollment date in your courses. For example, you can send announcements to learners who enrolled after a specific date or before a certain milestone.");gettext("Include students who have progressed");gettext("0% (Not started)");gettext("1-49%");gettext("50-99%");gettext("100% (Completed)");gettext("Discard");gettext("Discard announcement?");gettext("Are you sure you want to discard your changes? This action cannot be undone.");gettext("Save as draft");gettext("Submit announcement for review?");gettext("Submit for review");gettext("We'll review your announcement and send it afterwards. Proceed with submission?");gettext("Proceed");gettext("Cancel");gettext("Next");gettext("Draft saved");gettext("Your announcement draft is saved.");gettext("A problem occurred while saving the draft.");gettext("A problem occurred while creating the announcement.");gettext("Preview sent");gettext("Check your email for the announcement preview.");gettext("No announcement found");gettext("You need to save an announcement as draft before you can edit it.");gettext("Announcement detail");gettext("Please select at least one of the progress buckets");gettext("Please include at least %(min)s characters of content for the announcement");gettext("An unexpected error occurred. Please try again.");gettext("Please fill in the subject field");gettext("Please select at least one course")}function O(){gettext("Top-rated course");gettext("Practice exam course");gettext("Exam voucher deal");gettext("Get certified. Get ahead.");gettext("Boost your earning and promotion potential with a certification. Prep confidently with a top-rated course, practice exam, & exclusive exam voucher savings. ");gettext("Udemy: Online Courses for Skills, Careers & AI");gettext("Learn in-demand skills with online courses, get professional certificates that advance your career, and explore courses in AI, coding, business and more.")}var P=o("./src/udemy/js/utils/handle-import-error.js");var w=o("./src/udemy/js/loaders/dynamic-imports/emitter.js");function N(){w.c.addListener("ud-app",(e=>{const{onSuccess:t,onError:s}=L("ud-app",e,P.c);o("./src/udemy/js lazy recursive ^\\.\\/.*\\/udlite\\-app$")(`./${e}/udlite-app`).then(t).catch(s)}))}function L(e,t,o){return{onSuccess(o){w.c.emit(`${e}:${t}:success`,o)},onError(s){try{o(s);w.c.emit(`${e}:${t}:success`)}catch(o){w.c.emit(`${e}:${t}:failure`,o)}}}}var D=o("./src/udemy/js/loaders/ud-app-loader.js");function U(){gettext("Payout Report");gettext("Amount To Be Paid");gettext("Payout History");gettext("Created");gettext("Status");gettext("Payout method");gettext("Pre-tax amount");gettext("Withholding tax");gettext("Net earning");gettext("This is the money that is currently available to be paid out with the next payout.");gettext("Learn more about");gettext("our payout process");gettext("In case you have not received your payout");gettext("troubleshooting steps");gettext("We need your withholding tax information");gettext("Your payouts are currently paused due to missing tax information. Please provide your tax details to continue receiving payouts.");gettext("Submit tax documentation");gettext("We need your payout method");gettext("Your payouts are currently paused due to missing payout method information. Please provide your payout method details to continue receiving payouts.");gettext("Update payout method");gettext("Please note that the data provided is only available for the payouts following May 2018.");gettext("Success");gettext("Failed");gettext("Blocked");gettext("Cancelled");gettext("Initial");gettext("Pending");gettext("Processing");gettext("Queuing");gettext("Ready To Pay");gettext("Ready to pay");gettext("Unclaimed");gettext("Unpaid");gettext("Undefined");gettext("You can now review your payout history in detail. You can always find the link to the report at");gettext("Profile Picture -> Instructor Dashboard -> Payout Report");gettext("Payout report is available!");gettext("View payout report");gettext("The payout was attempted by Udemy but was not delivered. See the troubleshooting steps for actions you can take to resolve this.");gettext("The payout is currently being processed.");gettext("Your payout is in the queue. We will attempt to process it in at most 14 days.");gettext("We successfully sent your payout. It might take more time for your banking provider to fund your account.");gettext("The payout is currently blocked.");gettext("The payout has been cancelled or resent with a new payout.");gettext("The status of your payout is not defined in our system, which can occur with certain payout methods.")}function j(){gettext("Don't want to buy courses one by one? Pick a plan to help you, your team, or your organization achieve outcomes faster.");gettext("Choose a plan for success");gettext("For you");gettext("Billed annually. Cancel anytime.");gettext("Annual fee %(price)s (excl. tax)");gettext("Included in plan");gettext("Available with add-on");gettext("Starting at %(price)s per month");gettext("%(price)s a month per user");gettext("%(min)s to %(max)s people");gettext("Compare plans and features");gettext("Personal Plan");gettext("Individual");gettext("Try it free");gettext("Start subscription");gettext("Team Plan");gettext("Enterprise Plan");gettext("Contact sales for pricing");gettext("More than 20 people");gettext("More than 21 people");gettext("Request a demo");gettext("How are courses selected for the plans?");gettext("How is Personal Plan different from buying a course?");gettext("What languages does Enterprise Plan have content for?");gettext("What is Udemy Business Pro?");gettext("Each course included in our plans is curated from the %(courseCount)s+ courses in our overall catalog. Our content experts use insights from %(learnerCount)s Udemy learners to identify top-rated, relevant courses on the most sought-after professional topics as well as a selection of personal development topics.");gettext("With Personal Plan, your learning opportunities are endless. You’ll gain monthly access to our top-rated courses, coding exercises, and practice tests in a variety of professional and personal development categories. You can learn one skill or multiple skills at once. Alternatively, if you buy courses one at a time, you’ll get lifetime access to those courses only.");gettext("How is Leadership Academy different from Personal, Team, and Enterprise Plan?");gettext("All our plans offer the same core collection of top-rated Udemy courses. Enterprise Plan also includes our international collection with courses in 15 languages, advanced administrative features, and the ability to scale and customize learning for small to large-scale organizations. If you are part of a smaller organization or training an individual team, you can use Team Plan for up to 20 people to get all the course content of Personal Plan plus our basic administrative features.");gettext("Leadership Academy is not another plan option but a series of accelerated, guided learning programs that prepare leaders to address today’s most pressing organizational problems. Each program is uniquely built for your team, informed by research, facilitated by a subject-matter expert, and tailored to meet your organization’s specific needs through peer-to-peer engagement.");gettext("Enterprise Plan includes our international collection of original-language content in 16 languages, including English, Spanish, Portuguese, French, Italian, German, Indonesian, Japanese, Korean, Polish, Russian, Turkish, Arabic, Hindi, Vietnamese, and simplified and traditional Chinese.");gettext("With the Udemy Business Pro add-on for Enterprise Plan, you get access to a powerful combination of learning tools for your tech learners. In addition to the top-rated courses available with your plan, your employees can also take advantage of hands-on training features like assessments, labs, workspaces, and Udemy paths.");gettext("See what others are achieving through learning");gettext("Learner experience");gettext("Top-rated courses");gettext("Our marketplace allows us to monitor popular topics and surface emerging skills while learner ratings help us identify the most effective courses.");gettext("(including international collection)");gettext("Our international collection features original-language content in English, Portuguese, French, Italian, Indonesian, Japanese, Korean, Polish, Russian, Turkish, Arabic, Hindi, Vietnamese, and simplified and traditional Chinese.");gettext("Certification prep courses and practice tests");gettext("Prep employees for over 200 industry-recognized certification exams from issuers like AWS, Project Management Institute, Google, Microsoft, and more.");gettext("AI-powered coding exercises");gettext("Our instructors use AI to build Python, C++, Java, and Javascript coding exercises with solution code, test cases, and evaluation logic to provide learners with better exercises and comprehensive answers.");gettext("Goal-aligned recommendations");gettext("Instructor Q&A");gettext("Mobile app access");gettext("Admin experience");gettext("User adoption and engagement reports");gettext("24/7 customer support");gettext("Custom learning paths, courses, and user groups");gettext("In addition to adding resources and creating your own courses and learning paths, you can organize learners into teams, learning programs, and projects for easy management. ");gettext("User activity, learning trends, and benchmark insights");gettext("Admins can see what employees are learning and benchmark against industry standards.");gettext("Integration capabilities");gettext("Single sign-on, Application Programming Interface (API), Learning Management Systems (LMS), Slack, and workplace integration.");gettext("Udemy Pro add-on for tech learners");gettext("Skills assessments");gettext("Help learners evaluate their skills and get relevant recommendations for their level.");gettext("Labs and technical workspaces");gettext("Allow learners to practice in risk-free environments.");gettext("Pre-built paths");gettext("Our pre-built learning paths  include assessments, courses, and labs that align to popular certifications.");gettext("Advanced insights");gettext("Admins are able to monitor how learners are interacting with Udemy Pro features.");gettext("Compare Udemy Plans and Pricing | Udemy");gettext("Compare Udemy’s plans and choose the best learning solution for your upskilling needs. From personal to business subscription plans, you can find pricing plans that match your unique goals.");gettext("For your team");gettext("For your whole organization");gettext("Cohort programs to develop your leaders");gettext("Groups of 25 or more");gettext("Access to 25,000+ top courses");gettext("Certification prep");gettext("Goal-focused recommendations");gettext("AI-powered coding exercises");gettext("Advanced analytics and insights");gettext("Dedicated customer success team");gettext("International course collection featuring 15 languages");gettext("Customizable content");gettext("Hands-on tech training with add-on");gettext("Strategic implementation services with add-on");gettext("Access to 11,000+ top courses");gettext("Access to 12,000+ top courses");gettext("Access to 13,000+ top courses");gettext("Analytics and adoption reports");gettext("Expert-led leadership training");gettext("Research-based content curation");gettext("Applied learning, tool kits, and group coaching");gettext("Asynchronous learning with collaborative discussions");gettext("Live virtual events");gettext("AI-powered analytics and insights");gettext("Accelerate growth — for you or your organization");gettext("Accelerate growth - for your organization");gettext("Accelerate growth — for your organization");gettext("Reach goals faster with 